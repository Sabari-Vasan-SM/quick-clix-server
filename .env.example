# Server
PORT=5000
NODE_ENV=production

# Clipboard behavior
TTL_MINUTES=15
MAX_FILE_MB=25
MAX_TEXT_LENGTH=20000
MAX_ACTIVE_ITEMS=4000
CLEANUP_INTERVAL_SECONDS=60

# Comma-separated frontend origins. Leave empty only for local testing.
# Example Fly.io production value: https://quick-clix-web.fly.dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Rate limits per 15 minutes
RATE_LIMIT_GENERAL=300
RATE_LIMIT_UPLOAD=80
RATE_LIMIT_RETRIEVE=240
